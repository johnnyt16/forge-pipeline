# Database (Railway provides this automatically)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/forge_pipeline"

# Redis (Railway provides this automatically)
REDIS_URL="redis://localhost:6379"

# AI Provider
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
AI_PROVIDER="anthropic"  # "openai" or "anthropic"

# Runtime URL — where the sites-runtime service is accessible
# Local dev: http://localhost:3001
# Railway: https://sites-runtime-production-xxxx.up.railway.app (or custom domain)
RUNTIME_URL="http://localhost:3001"
